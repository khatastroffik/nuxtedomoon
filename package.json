{
  "name": "nuxtedomoon",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Nuxtedo-Moon is a responsive portfolio/blog static web page template designed using Nuxt, Nuxt-Content, Tailwind CSS and daisyUI.",
  "author": "khatastroffik",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/khatastroffik/nuxtedomoon.git",
    "type": "git"
  },
  "bugs": {
    "url": "https://github.com/khatastroffik/treefolder/issues"
  },
  "keywords": [
    "typescript",
    "Nuxt",
    "portfolio",
    "khatastroffik",
    "blog",
    "template",
    "TailwindCSS",
    "daisyUI",
    "k11k"
  ],
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "prep": "nuxt prepare",
    "prepare": "husky",
    "lint": "eslint .",
    "lintix": "eslint . --fix",
    "dry-commit": "git hook run pre-commit",
    "cleanup": "nuxt cleanup",
    "reset": "rimraf node_modules pnpm-lock.yaml dist .cache .output .nuxt .data",
    "ninfo": "nuxt info",
    "serve": "pnpx serve .output/public",
    "node": "node .output/server/index.mjs",
    "http": "pnpx http-server .output/public",
    "http:base": "pnpx https://github.com/http-party/http-server.git#5ec4848383dc10391a8a63ffa52d3b01d111e292 .output/public -c-1 --base-dir nuxtedomoon"
  },
  "dependencies": {
    "@iconify-json/tabler": "^1.2.28",
    "@nuxt/content": "^3.12.0",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/icon": "2.2.1",
    "@nuxt/image": "2.0.0",
    "@nuxtjs/color-mode": "4.0.0",
    "@nuxtjs/seo": "5.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@takumi-rs/core": "1.0.0-beta.20",
    "@vueuse/core": "^14.1.18",
    "better-sqlite3": "^12.6.2",
    "daisyui": "^5.5.19",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.4.3",
    "eslint": "^9.39.2",
    "eslint-plugin-format": "^1.4.0",
    "eslint-plugin-tailwindcss": "4.0.0-beta.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.4"
  },
  "lint-staged": {
    "*": "pnpm lint"
  }
}
