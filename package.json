{
  "name": "nuxtedomoon",
  "type": "module",
  "version": "0.5.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Nuxtedo-Moon is a responsive portfolio/blog static web page template designed using Nuxt, Nuxt-Content, Nuxt-SEO, Tailwind CSS and daisyUI.",
  "author": "khatastroffik",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/khatastroffik/nuxtedomoon.git",
    "type": "git"
  },
  "bugs": {
    "url": "https://github.com/khatastroffik/treefolder/issues"
  },
  "keywords": [
    "typescript",
    "Nuxt",
    "portfolio",
    "khatastroffik",
    "blog",
    "template",
    "TailwindCSS",
    "daisyUI",
    "k11k"
  ],
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "prep": "nuxt prepare",
    "prepare": "husky",
    "lint": "eslint .",
    "lintix": "eslint . --fix",
    "dry-commit": "git hook run pre-commit",
    "cleanup": "nuxt cleanup",
    "reset": "rimraf node_modules pnpm-lock.yaml dist .cache .output .nuxt .data",
    "ninfo": "nuxt info",
    "serve": "pnpx serve .output/public",
    "node": "node .output/server/index.mjs",
    "http": "pnpx http-server .output/public",
    "http:base": "pnpx https://github.com/http-party/http-server.git#5ec4848383dc10391a8a63ffa52d3b01d111e292 .output/public -c-1 --base-dir nuxtedomoon",
    "do:bump": "bumpp --commit \"release v\" --print-commits --all --execute \"git add CHANGELOG.md\"",
    "do:changelog": "pnpx changelogithub --output CHANGELOG.md",
    "do:release": "pnpm do:changelog && pnpm do:bump"
  },
  "dependencies": {
    "@iconify-json/iconoir": "^1.2.11",
    "@iconify-json/lucide": "^1.2.103",
    "@iconify-json/simple-icons": "^1.2.79",
    "@iconify-json/tabler": "^1.2.33",
    "@nuxt/content": "^3.13.0",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/icon": "2.2.1",
    "@nuxt/image": "2.0.0",
    "@nuxtjs/color-mode": "4.0.0",
    "@nuxtjs/seo": "5.1.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@takumi-rs/core": "1.1.2",
    "@vueuse/core": "^14.2.1",
    "better-sqlite3": "^12.9.0",
    "daisyui": "^5.5.19",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.4.3",
    "bumpp": "^11.0.1",
    "eslint": "^9.39.2",
    "eslint-plugin-format": "^1.4.0",
    "eslint-plugin-tailwindcss": "4.0.0-beta.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.2.7"
  },
  "lint-staged": {
    "*": "pnpm lint"
  },
  "changelogithub": {
    "types": {
      "feat": {
        "title": "🚀 Features"
      },
      "fix": {
        "title": "🐞 Bug Fixes"
      },
      "perf": {
        "title": "✨ Performance"
      },
      "improve": {
        "title": "✨ Improvements"
      },
      "docs": {
        "title": "📖 Documentation"
      },
      "test": {
        "title": "⚙️ Tests"
      },
      "refactor": {
        "title": "⚙️ Refactors"
      },
      "build": {
        "title": "⚙️ Build"
      },
      "ci": {
        "title": "⚙️ CI"
      },
      "chore": {
        "title": "⚙️ Chore"
      }
    },
    "excludeTypes": [],
    "titles": {
      "breakingChanges": "🚨 Breaking Changes 🚨"
    },
    "capitalize": true,
    "group": true,
    "emoji": true
  }
}
