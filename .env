# +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
# Site URL i.e. the protocol + domain/host + port (optional) of the server where the app is deployed.
# +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
NUXT_PUBLIC_SITE_URL=https://khatastroffik.github.io

# +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
# Uncomment the "NUXT_APP_BASE_URL" line below to implement a web site under a specific URI-path
# like:  https://example.com/this-is-the-path/
#
# You can simulate the server i.e. test the web site under baseURL circumstances using the script 
# (adapted) "http:base" in the package.json file i.e running "pnpm http:base" in your shell.
#
# For a **GitHub page** bound to your repository, the path should correspond to the name of the repo.
# +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
NUXT_APP_BASE_URL=/nuxtedomoon/
